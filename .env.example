# =============================================================
# Project Link dev container environment
# Copy this file to .env and fill in actual values.
# NEVER commit .env to git.
# Non-secret defaults belong in template.ini.
#
# Port policy:
# - 20000-20099: shared auth platform
# - 20100-20199: this game stack
# - Container-to-container traffic uses service names: db:5432, redis:6379
# - Host ports are only for tools running on the PC/server host
# =============================================================

# ----- Compose / Containers -----
COMPOSE_PROJECT_NAME=project-link

# Dev: use 0.0.0.0 if a phone or another LAN device must call the API.
# Prod: use 127.0.0.1 and expose only 80/443 through a reverse proxy.
API_HOST_BIND=127.0.0.1
API_HOST_PORT=20101
API_CONTAINER_PORT=8080

# PostgreSQL is exposed to the host for pgAdmin 4 and gen:orm.
# Prod should keep this bound to 127.0.0.1 and access it through SSH tunnel only.
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=20132
POSTGRES_CONTAINER_HOST=db
POSTGRES_CONTAINER_PORT=5432

# Redis is not published by docker-compose.yml by default.
# API still reaches Redis internally through redis:6379.
REDIS_CONTAINER_HOST=redis
REDIS_CONTAINER_PORT=6379

# ----- PostgreSQL -----
DB_TYPE=postgresql
# Supported: postgresql, mysql, sqlite

POSTGRES_DB=projectlink_db
POSTGRES_USER=postgres
DB_PASSWORD=change_me
POSTGRES_PASSWORD=change_me

# Host-side tools (npm run gen:orm) connect through the published PostgreSQL port.
DB_HOST=localhost
DB_PORT=20132

# For SQLite only (path to .db file)
# DB_FILE=server/db/game.db

# ----- Server -----
NODE_ENV=development
APP_CLIENT_ID=projectlink
APP_ALLOWED_CLIENT_VERSION=1.0.0
APP_ALLOWED_PROTOCOL_VERSION=1

# ----- Auth / Security -----
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=7d
JWT_AUTHORITY=
JWT_AUDIENCE=projectlink

# ----- GitHub Integration (optional local automation) -----
GITHUB_TOKEN=
GITHUB_REPO_URL=https://github.com/zzzz955/project-link
GITHUB_DEFAULT_PROJECT=project-link
GITHUB_DEFAULT_ASSIGNEE=zzzz955

# ----- gen:orm override (optional, overrides template.ini) -----
# GEN_ORM_DRY_RUN=true
